---
/*
 * /pricing/ — subscription pricing page (localized).
 *
 * Card LAYOUT + COPY mirror the vela subscription modal (`pricing-plans.tsx`).
 * The NUMBERS come from `PRICING_SNAPSHOT` at build time and are reconciled
 * from `PLANS_JSON_URL` by the inline script after validating the public JSON
 * contract. The localized TEXT comes from app/_lib/pricing-content.ts.
 * Numbers and text are kept separate on purpose: only numbers are part of the
 * plans.json contract.
 */
import Layout from '../../_components/sub-page-layout.astro';
import {
  PRICING_SNAPSHOT,
  PLANS_JSON_URL,
  CLOUD_CONSOLE_URL,
  cloudSubscribeUrl,
  type PlanTierConfig,
} from '../../_lib/pricing';
import {
  getPricingContent,
  fillTemplate,
  PREMIUM_MODELS,
  STANDARD_MODELS,
  DELIVERABLE_RANGES,
  CREDIT_BONUS_PCT,
  TEAM_SIZE_VALUES,
  BUDGET_VALUES,
  type PlanTierId,
} from '../../_lib/pricing-content';
import {
  getStory,
  getFaqs,
  getFaqTitle,
  getEnterprise,
  ENTERPRISE_EMAIL,
} from '../../_lib/pricing-extras-content';
import { getCatalogCounts } from '../../_lib/catalog';
import { localeFromPath, localizedHref } from '../../i18n';

const locale = localeFromPath(Astro.url.pathname);
const href = (path: string) => localizedHref(path, locale);
const content = getPricingContent(locale);
const L = content.labels;
const catalogCounts = await getCatalogCounts(locale);
const catalogLabelVars = {
  skillsCount: catalogCounts.skills.toLocaleString('en-US'),
  systemsCount: catalogCounts.systems.toLocaleString('en-US'),
};

// Footer line with the cloud-console link injected into the localized
// template. Brand/URL only — safe to render as HTML.
const footnoteHtml = fillTemplate(L.footnote, {
  console: `<a class="inline-link" href="${CLOUD_CONSOLE_URL}">${L.consoleLabel}</a>`,
});

// Customer story + FAQ below the cards (mirrors vela's modal). "Read more"
// points at the marketing site's own Ikigai One story page.
const story = getStory(locale);
const faqs = getFaqs(locale);
const faqTitle = getFaqTitle(locale);
const storyMoreHref = href('/stories/ikigai-one/');
const enterprise = getEnterprise(locale);
const LF = enterprise.leadForm;

const SITE = Astro.site?.toString() ?? 'https://open-design.ai/';
const title = 'Pricing — Open Design';
const description =
  'Open Design subscription plans. Plus, Pro, and Max tiers with monthly credits, one-click deployments, and auto top-up — one unified balance for every Open Design call.';

const tiers: PlanTierConfig[] = PRICING_SNAPSHOT.tiers;
const usd = (n: number) => `$${Math.round(n).toLocaleString('en-US')}`;
const renderCatalogLabel = (label: string) => fillTemplate(label, catalogLabelVars);

// Displayed monthly credit = base grant × the limited-time bonus (Pro +20%,
// Max +50%). The base grant stays the plans.json contract number; the bonus is
// a promo surfaced as a badge next to the amount.
function effectiveCreditUsd(t: PlanTierConfig): number {
  const bonusPct = CREDIT_BONUS_PCT[t.tier as PlanTierId];
  return bonusPct ? Math.round(t.monthly.grantUsd * (1 + bonusPct / 100)) : t.monthly.grantUsd;
}

// Build-time display values per tier (the inline script recomputes these from
// the public plans.json using the same formulas + the same label templates).
function view(t: PlanTierConfig) {
  const introPct = Math.round((1 - t.monthly.introPriceUsd / t.monthly.priceUsd) * 100);
  const yearlyEquiv = Math.round(t.yearly.priceUsd / 12);
  const yearlySave = t.monthly.priceUsd * 12 - t.yearly.priceUsd;
  return {
    monthly: {
      amount: usd(t.monthly.introPriceUsd),
      strike: usd(t.monthly.priceUsd),
      tag: fillTemplate(L.firstMonthTag, { pct: String(introPct) }),
      subline: fillTemplate(L.monthlyRenewal, { amountUsd: usd(t.monthly.priceUsd) }),
      saveCta: fillTemplate(L.yearlySaveCta, { savingsUsd: usd(yearlySave) }),
    },
    yearly: {
      amount: usd(yearlyEquiv),
      strike: usd(t.monthly.priceUsd),
      tag: fillTemplate(L.yearlyDiscountTag, { pct: String(t.yearly.discountPct) }),
      subline: fillTemplate(L.yearlySubline, {
        totalUsd: usd(t.yearly.priceUsd),
        savingsUsd: usd(yearlySave),
      }),
    },
    credits: fillTemplate(L.creditBenefit, { amount: usd(effectiveCreditUsd(t)) }),
    bonusPct: CREDIT_BONUS_PCT[t.tier as PlanTierId],
  };
}

const absUrl = (path: string) => new URL(href(path), SITE).toString();
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Open Design', item: absUrl('/') },
      { '@type': 'ListItem', position: 2, name: 'Pricing', item: absUrl('/pricing/') },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Open Design Subscription',
    description,
    offers: tiers.map((t) => ({
      '@type': 'Offer',
      name: `Open Design ${t.tier}`,
      price: String(t.monthly.priceUsd),
      priceCurrency: 'USD',
      url: CLOUD_CONSOLE_URL,
    })),
  },
];
---

<Layout title={title} description={description} active="pricing" jsonLd={jsonLd}>
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href={href('/')}>Open Design</a>
    <span>/</span>
    <span aria-current="page">Pricing</span>
  </nav>

  <article class="info-page pr-page" data-pricing-root data-interval="yearly">
    <header class="pr-hero">
      <h1 class="pr-hero-heading">{L.heroTitle}</h1>
      <div class="pr-toggle" role="tablist" aria-label="Billing interval">
        <button type="button" class="pr-toggle-btn" role="tab" data-interval-btn="monthly" aria-selected="false">
          {L.monthly}
        </button>
        <button type="button" class="pr-toggle-btn is-active" role="tab" data-interval-btn="yearly" aria-selected="true">
          {L.yearly}
          <span class="pr-toggle-save">{L.yearlySave}</span>
        </button>
      </div>
    </header>

    <section class="pr-grid" aria-label="Subscription plans">
      {tiers.map((t) => {
        const v = view(t);
        const plan = content.plans[t.tier as PlanTierId];
        return (
          <article class="pr-card" data-tier={t.tier} data-recommended={t.recommended ? 'true' : undefined}>
            <header class="pr-head">
              <img
                class="pr-tier-logo"
                src={`/pricing/plan-${t.tier}.svg`}
                alt={t.tier.charAt(0).toUpperCase() + t.tier.slice(1)}
                height={22}
                loading="lazy"
                decoding="async"
              />
              <p class="pr-tagline">{plan.tagline}</p>
            </header>

            <div class="pr-price">
              <div class="pr-when" data-when="monthly">
                <div class="pr-price-row">
                  <span class="pr-amount" data-od-amount>{v.monthly.amount}</span>
                  <s class="pr-strike" data-od-strike>{v.monthly.strike}</s>
                  <span class="pr-per">{L.perMonth}</span>
                  <span class="pr-tag" data-od-tag>{v.monthly.tag}</span>
                </div>
                <p class="pr-subline">
                  <span data-od-subline>{v.monthly.subline}</span>
                  <button type="button" class="pr-yearly-nudge" data-goto-yearly>
                    <span data-od-yearly-cta>{v.monthly.saveCta}</span>
                    <span class="pr-yearly-nudge-arrow" aria-hidden="true">→</span>
                  </button>
                </p>
              </div>
              <div class="pr-when" data-when="yearly">
                <div class="pr-price-row">
                  <span class="pr-amount" data-od-amount>{v.yearly.amount}</span>
                  <s class="pr-strike" data-od-strike>{v.yearly.strike}</s>
                  <span class="pr-per">{L.perMonth}</span>
                  <span class="pr-tag" data-od-tag>{v.yearly.tag}</span>
                </div>
                <p class="pr-subline" data-od-subline>{v.yearly.subline}</p>
              </div>
            </div>

            <p class="pr-anchor">{plan.costAnchor}</p>

            <a
              class={t.recommended ? 'btn btn-primary pr-cta' : 'btn btn-ghost pr-cta'}
              href={cloudSubscribeUrl(t.tier, 'yearly')}
              data-pricing-cta
              data-tier={t.tier}
            >
              {plan.ctaLabel}
            </a>

            {/* Fully-expanded benefits — credit + deliverable lead the list,
                then every included benefit; no "includes all <tier>" heading. */}
            <ul class="pr-feats">
              <li class="pr-feat pr-feat-lead">
                <span data-od-credit>{v.credits}</span>
                {v.bonusPct != null && (
                  <span class="pr-bonus">
                    <svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <rect x="3" y="8" width="18" height="4" rx="1" />
                      <path d="M12 8v13M19 12v7a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-7" />
                      <path d="M7.5 8a2.5 2.5 0 0 1 0-5C11 3 12 8 12 8s1-5 4.5-5a2.5 2.5 0 0 1 0 5" />
                    </svg>
                    {fillTemplate(L.creditBonus, { pct: String(v.bonusPct) })}
                  </span>
                )}
              </li>
              <li class="pr-feat pr-feat-lead pr-feat-task">
                <span>{fillTemplate(L.deliverableBenefit, { range: DELIVERABLE_RANGES[t.tier as PlanTierId] })}</span>
                <button type="button" class="pr-info-btn" aria-label={L.taskTooltip.note} aria-describedby={`pr-task-tip-${t.tier}`}>
                  <svg class="pr-info-icon" viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="10" />
                    <path d="M12 16v-4M12 8h.01" />
                  </svg>
                </button>
                <span class="pr-task-tip" id={`pr-task-tip-${t.tier}`} role="tooltip">
                  <span>{L.taskTooltip.line1}</span>
                  <span>{L.taskTooltip.line2}</span>
                  <span class="pr-task-tip-note">{L.taskTooltip.note}</span>
                </span>
              </li>
              {plan.features.map((f) => (
                <li class="pr-feat">{renderCatalogLabel(f)}</li>
              ))}
            </ul>

            <div class="pr-models">
              <p class="pr-models-head">{L.premiumModels}</p>
              <ul class="pr-model-list">
                {PREMIUM_MODELS.map((m) => <li>{m}</li>)}
              </ul>
              <p class="pr-models-head">{L.standardModels}</p>
              <ul class="pr-model-list">
                {STANDARD_MODELS.map((m) => <li>{m}</li>)}
              </ul>
            </div>
          </article>
        );
      })}
    </section>

    <p class="pr-foot" set:html={footnoteHtml} />
  </article>

  <section class="pr-team" aria-label={enterprise.title}>
    <div class="pr-team-row">
      <div class="pr-team-lead">
        <span class="pr-team-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 21h18" />
            <path d="M5 21V7l7-4 7 4v14" />
            <path d="M9 9h.01M9 13h.01M9 17h.01M15 9h.01M15 13h.01M15 17h.01" />
          </svg>
        </span>
        <div>
          <div class="pr-team-head">
            <h3 class="pr-team-title">{enterprise.title}</h3>
            <span class="pr-team-badge">{enterprise.badge}</span>
          </div>
          <p class="pr-team-desc">{enterprise.description}</p>
        </div>
      </div>
      <div class="pr-team-actions">
        <button type="button" class="btn btn-primary pr-team-cta" data-open-lead-modal>
          {enterprise.leadCta}
        </button>
        <a class="pr-team-email" href={`mailto:${ENTERPRISE_EMAIL}`}>
          <span aria-hidden="true">✉</span> {ENTERPRISE_EMAIL}
        </a>
      </div>
    </div>
    <ul class="pr-team-feats">
      {enterprise.features.map((f) => <li>{f}</li>)}
    </ul>
  </section>

  <section class="pr-story" aria-label={story.eyebrow}>
    <div class="pr-story-head">
      <p class="pr-story-eyebrow">{story.eyebrow}</p>
      <a class="pr-story-more" href={storyMoreHref}>
        {story.more}<span aria-hidden="true"> →</span>
      </a>
    </div>
    <div class="pr-story-card">
      <div class="pr-story-body">
        <blockquote class="pr-story-quote">
          <span class="pr-q" aria-hidden="true">“</span>{story.quote.lead}<span class="pr-hl">{story.quote.highlight}</span>{story.quote.tail}<span class="pr-q" aria-hidden="true">”</span>
        </blockquote>
        <div class="pr-story-person">
          <span class="pr-story-avatar" aria-hidden="true">I</span>
          <div>
            <div class="pr-story-name">{story.name}</div>
            <div class="pr-story-role">{story.role}</div>
          </div>
        </div>
        <div class="pr-story-chips">
          {story.chips.map((chip) => <span class="pr-chip">{chip}</span>)}
        </div>
        <div class="pr-story-stats">
          {story.stats.map((stat) => (
            <div class="pr-stat">
              <div class="pr-stat-val">{stat.value}</div>
              <div class="pr-stat-label">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
      <img
        class="pr-story-cover"
        src="/stories/ikigai-one-cover.webp"
        alt={`${story.name} — ${story.role}`}
        width={800}
        height={450}
        loading="lazy"
        decoding="async"
      />
    </div>
  </section>

  <section class="pr-faq" aria-label={faqTitle}>
    <h2 class="pr-faq-title">{faqTitle}</h2>
    <div class="pr-faq-list">
      {faqs.map((faq) => (
        <details class="pr-faq-item">
          <summary class="pr-faq-q">{faq.q}</summary>
          <div class="pr-faq-a">{faq.a}</div>
        </details>
      ))}
    </div>
  </section>

  {/* Team-plan lead-capture modal — opened by the "Request team access" CTA in
      the team banner. POSTs to the /contact-sales Pages Function. */}
  <div class="pr-modal" data-lead-modal hidden aria-hidden="true">
    <div class="pr-modal-backdrop" data-lead-close></div>
    <div class="pr-modal-card" role="dialog" aria-modal="true" aria-labelledby="pr-lead-title">
      <button type="button" class="pr-modal-x" data-lead-close aria-label={LF.close}>
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
          <path d="M6 6l12 12M18 6L6 18" />
        </svg>
      </button>

      <form class="pr-lead-form" data-lead-form novalidate>
        <h2 class="pr-modal-title" id="pr-lead-title">{LF.title}</h2>
        <p class="pr-modal-sub">{LF.subtitle}</p>

        <div class="pr-lead-grid">
          <div class="pr-lead-field">
            <label class="pr-lead-label" for="pr-lead-name">{LF.fields.name} <span class="pr-req">*</span></label>
            <input class="pr-lead-input" id="pr-lead-name" name="name" type="text" required autocomplete="name" placeholder={LF.placeholders.name} />
          </div>
          <div class="pr-lead-field">
            <label class="pr-lead-label" for="pr-lead-email">{LF.fields.email} <span class="pr-req">*</span></label>
            <input class="pr-lead-input" id="pr-lead-email" name="email" type="email" required autocomplete="email" placeholder={LF.placeholders.email} />
          </div>
          <div class="pr-lead-field">
            <label class="pr-lead-label" for="pr-lead-company">{LF.fields.company} <span class="pr-opt">{LF.optional}</span></label>
            <input class="pr-lead-input" id="pr-lead-company" name="company" type="text" autocomplete="organization" placeholder={LF.placeholders.company} />
          </div>
          <div class="pr-lead-field">
            <label class="pr-lead-label" for="pr-lead-teamsize">{LF.fields.teamSize} <span class="pr-opt">{LF.optional}</span></label>
            <select class="pr-lead-input pr-lead-select" id="pr-lead-teamsize" name="teamSize">
              <option value="">{LF.selectPlaceholder}</option>
              {LF.teamSizeOptions.map((label, i) => <option value={TEAM_SIZE_VALUES[i]}>{label}</option>)}
            </select>
          </div>
          <div class="pr-lead-field">
            <label class="pr-lead-label" for="pr-lead-role">{LF.fields.role} <span class="pr-opt">{LF.optional}</span></label>
            <input class="pr-lead-input" id="pr-lead-role" name="role" type="text" placeholder={LF.placeholders.role} />
          </div>
          <div class="pr-lead-field">
            <label class="pr-lead-label" for="pr-lead-location">{LF.fields.country} <span class="pr-opt">{LF.optional}</span></label>
            <input class="pr-lead-input" id="pr-lead-location" name="location" type="text" placeholder={LF.placeholders.country} />
          </div>
          <div class="pr-lead-field">
            <label class="pr-lead-label" for="pr-lead-seats">{LF.fields.seats} <span class="pr-opt">{LF.optional}</span></label>
            <input class="pr-lead-input" id="pr-lead-seats" name="seats" type="text" inputmode="numeric" placeholder={LF.placeholders.seats} />
          </div>
          <div class="pr-lead-field">
            <label class="pr-lead-label" for="pr-lead-budget">{LF.fields.budget} <span class="pr-opt">{LF.optional}</span></label>
            <select class="pr-lead-input pr-lead-select" id="pr-lead-budget" name="budget">
              <option value="">{LF.selectPlaceholder}</option>
              {LF.budgetOptions.map((label, i) => <option value={BUDGET_VALUES[i]}>{label}</option>)}
            </select>
          </div>
          <div class="pr-lead-field pr-lead-field-full">
            <label class="pr-lead-label" for="pr-lead-message">{LF.fields.useCase} <span class="pr-opt">{LF.optional}</span></label>
            <textarea class="pr-lead-input pr-lead-textarea" id="pr-lead-message" name="message" rows="3" placeholder={LF.placeholders.useCase}></textarea>
          </div>
        </div>

        <p class="pr-lead-error" data-lead-error role="alert" hidden></p>
        <button type="submit" class="btn btn-primary pr-lead-submit" data-lead-submit>{LF.submit}</button>
        <p class="pr-lead-privacy">{LF.privacy}</p>
      </form>

      <div class="pr-lead-success" data-lead-success hidden>
        <span class="pr-lead-success-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 6L9 17l-5-5" />
          </svg>
        </span>
        <h3 class="pr-lead-success-title">{LF.successTitle}</h3>
        <p class="pr-lead-success-desc">{LF.successDesc}</p>
        <button type="button" class="btn btn-ghost pr-lead-success-close" data-lead-close>{LF.close}</button>
      </div>
    </div>
  </div>

  <script is:inline define:vars={{ plansUrl: PLANS_JSON_URL, labels: L, subscribeBase: CLOUD_CONSOLE_URL, creditBonusPct: CREDIT_BONUS_PCT, leadForm: LF }}>
    (() => {
      const root = document.querySelector('[data-pricing-root]');
      if (!root) return;

      // Shared analytics helper — same PostHog sink as the rest of the site
      // (window.__odTrack, guarded). Stamps page_name + locale on every event.
      const track = (name, extra) => {
        try {
          if (typeof window.__odTrack === 'function') {
            window.__odTrack(
              name,
              Object.assign(
                { page_name: 'pricing', locale: (document.documentElement.getAttribute('lang') || 'en').toLowerCase() },
                extra || {},
              ),
            );
          }
        } catch (e) {}
      };

      // Keep each plan's CTA deep-link pointing at the cloud console with the
      // currently selected billing interval. The console is auth-gated and
      // resumes this same intent after login; checkout=auto asks it to open
      // Stripe checkout for the tier immediately.
      const syncCtas = (interval) => {
        for (const cta of root.querySelectorAll('[data-pricing-cta]')) {
          const tier = cta.getAttribute('data-tier') || '';
          const q = new URLSearchParams({ view: 'plans', plan: tier, interval, checkout: 'auto' });
          cta.setAttribute('href', subscribeBase + '?' + q.toString());
        }
      };

      // ── Billing interval toggle ──────────────────────────────────────────
      // One entry point so the toggle button and the "save $X yearly" nudge
      // share state updates AND emit one analytics event with the right source.
      const activateInterval = (interval, via) => {
        root.setAttribute('data-interval', interval);
        for (const b of root.querySelectorAll('[data-interval-btn]')) {
          const on = b.getAttribute('data-interval-btn') === interval;
          b.classList.toggle('is-active', on);
          b.setAttribute('aria-selected', on ? 'true' : 'false');
        }
        syncCtas(interval);
        track('pricing_interval_toggle', { interval: interval, via: via || 'toggle' });
      };

      for (const btn of root.querySelectorAll('[data-interval-btn]')) {
        btn.addEventListener('click', () => activateInterval(btn.getAttribute('data-interval-btn'), 'toggle'));
      }

      // Monthly-tab "save $X yearly" nudge → switch to the yearly tab.
      for (const nudge of root.querySelectorAll('[data-goto-yearly]')) {
        nudge.addEventListener('click', () => activateInterval('yearly', 'nudge'));
      }

      // ── Pricing contract reconciliation ──────────────────────────────────
      // Same formulas + same label templates as the build-time render, applied
      // to the published JSON contract. Falls back to the baked snapshot.
      const usd = (n) => '$' + Math.round(n).toLocaleString('en-US');
      const fill = (tpl, vals) => tpl.replace(/\{(\w+)\}/g, (_, k) => (k in vals ? vals[k] : '{' + k + '}'));
      const set = (scope, sel, text) => {
        const el = root.querySelector(scope + ' ' + sel);
        if (el) el.textContent = text;
      };

      fetch(plansUrl, { headers: { Accept: 'application/json' } })
        .then((r) => {
          const contentType = r.headers.get('content-type') || '';
          return r.ok && contentType.includes('application/json') ? r.json() : null;
        })
        .then((data) => {
          if (!data || !Array.isArray(data.tiers)) return;
          for (const t of data.tiers) {
            if (!t || typeof t.tier !== 'string' || !t.monthly || !t.yearly) continue;
            const card = '[data-tier="' + t.tier + '"]';
            const introPct = Math.round((1 - t.monthly.introPriceUsd / t.monthly.priceUsd) * 100);
            const yearlyEquiv = Math.round(t.yearly.priceUsd / 12);
            const yearlySave = t.monthly.priceUsd * 12 - t.yearly.priceUsd;

            set(card, '[data-when="monthly"] [data-od-amount]', usd(t.monthly.introPriceUsd));
            set(card, '[data-when="monthly"] [data-od-strike]', usd(t.monthly.priceUsd));
            set(card, '[data-when="monthly"] [data-od-tag]', fill(labels.firstMonthTag, { pct: String(introPct) }));
            set(card, '[data-when="monthly"] [data-od-subline]', fill(labels.monthlyRenewal, { amountUsd: usd(t.monthly.priceUsd) }));
            set(card, '[data-when="monthly"] [data-od-yearly-cta]', fill(labels.yearlySaveCta, { savingsUsd: usd(yearlySave) }));

            set(card, '[data-when="yearly"] [data-od-amount]', usd(yearlyEquiv));
            set(card, '[data-when="yearly"] [data-od-strike]', usd(t.monthly.priceUsd));
            set(card, '[data-when="yearly"] [data-od-tag]', fill(labels.yearlyDiscountTag, { pct: String(t.yearly.discountPct) }));
            set(card, '[data-when="yearly"] [data-od-subline]', fill(labels.yearlySubline, { totalUsd: usd(t.yearly.priceUsd), savingsUsd: usd(yearlySave) }));

            const bonusPct = creditBonusPct[t.tier];
            const effectiveGrant = bonusPct ? Math.round(t.monthly.grantUsd * (1 + bonusPct / 100)) : t.monthly.grantUsd;
            set(card, '[data-od-credit]', fill(labels.creditBenefit, { amount: usd(effectiveGrant) }));
          }
        })
        .catch(() => {});

      // CTA analytics.
      root.addEventListener('click', (event) => {
        const cta = event.target && event.target.closest && event.target.closest('[data-pricing-cta]');
        if (!cta) return;
        try {
          const props = {
            page_name: 'pricing',
            tier: cta.getAttribute('data-tier') || 'unknown',
            interval: root.getAttribute('data-interval') || 'monthly',
          };
          if (typeof window.__odTrack === 'function') window.__odTrack('pricing_subscribe_click', props);
          else if (window.posthog && window.posthog.capture) window.posthog.capture('pricing_subscribe_click', props);
        } catch (e) {}
      });

      // ── Team-plan lead-capture modal ─────────────────────────────────────
      // The banner + modal live OUTSIDE [data-pricing-root], so query document.
      const modal = document.querySelector('[data-lead-modal]');
      if (modal) {
        const form = modal.querySelector('[data-lead-form]');
        const errorEl = modal.querySelector('[data-lead-error]');
        const successEl = modal.querySelector('[data-lead-success]');
        const submitBtn = modal.querySelector('[data-lead-submit]');
        let lastFocus = null;

        const openModal = () => {
          lastFocus = document.activeElement;
          // Restore a clean form on every open so a prior success/error panel
          // doesn't strand the modal (a second lead can be submitted freely).
          if (form) { form.reset(); form.hidden = false; }
          if (successEl) successEl.hidden = true;
          if (errorEl) errorEl.hidden = true;
          if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = leadForm.submit; }
          modal.hidden = false;
          modal.setAttribute('aria-hidden', 'false');
          document.body.style.overflow = 'hidden';
          const first = modal.querySelector('input[name="name"]');
          if (first) setTimeout(() => first.focus(), 40);
        };
        const closeModal = () => {
          modal.hidden = true;
          modal.setAttribute('aria-hidden', 'true');
          document.body.style.overflow = '';
          if (lastFocus && lastFocus.focus) lastFocus.focus();
        };

        for (const btn of document.querySelectorAll('[data-open-lead-modal]')) {
          btn.addEventListener('click', () => {
            track('team_lead_open', { area: 'team_banner' });
            openModal();
          });
        }
        for (const el of modal.querySelectorAll('[data-lead-close]')) {
          el.addEventListener('click', closeModal);
        }
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && !modal.hidden) closeModal();
        });

        const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        const showError = (msg) => {
          if (!errorEl) return;
          errorEl.textContent = msg;
          errorEl.hidden = false;
        };

        if (form) {
          form.addEventListener('submit', async (e) => {
            e.preventDefault();
            const data = new FormData(form);
            const val = (k) => (data.get(k) || '').toString().trim();
            const name = val('name');
            const email = val('email');
            if (!name || !email) return showError(leadForm.errorRequired);
            if (!EMAIL_RE.test(email)) return showError(leadForm.errorEmail);
            if (errorEl) errorEl.hidden = true;
            if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = leadForm.submitting; }

            const payload = {
              name, email,
              company: val('company'),
              teamSize: (data.get('teamSize') || '').toString(),
              role: val('role'),
              location: val('location'),
              seats: val('seats'),
              budget: (data.get('budget') || '').toString(),
              message: val('message'),
              source: 'pricing_team',
              locale: document.documentElement.lang || 'en',
              pageUrl: location.href,
            };

            try {
              const res = await fetch('/contact-sales', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload),
              });
              const body = await res.json().catch(() => ({}));
              if (!res.ok || !body.ok) throw new Error('failed');
              form.hidden = true;
              if (successEl) successEl.hidden = false;
              // Success conversion — segmentation props only, no PII (name/email
              // stay out of the analytics payload).
              track('team_lead_submit', {
                team_size: payload.teamSize || '(none)',
                budget: payload.budget || '(none)',
                has_company: !!payload.company,
                has_role: !!payload.role,
                has_seats: !!payload.seats,
                has_message: !!payload.message,
              });
            } catch (err) {
              // Client-side validation already passed, so a failure here is
              // transient/network — show the submit-failure hint, not a
              // "fill required fields" message, and let the user retry.
              showError(leadForm.errorSubmit);
              track('team_lead_error', {});
              if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = leadForm.submit; }
            }
          });
        }
      }
    })();
  </script>
</Layout>

